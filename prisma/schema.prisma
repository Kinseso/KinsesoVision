generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  files File[]
}

model File {
  id        String   @id @default(cuid())
  name      String?
  path      String?
  type      String?
  size      Int?
  ownerId   String?
  createdAt DateTime @default(now())

  owner  User?   @relation(fields: [ownerId], references: [id])
  shares Share[]
}

model Share {
  id        String   @id @default(cuid())
  fileId    String
  token     String   @unique
  createdAt DateTime @default(now())

  file File @relation(fields: [fileId], references: [id])
}

model Incident {
  id          String   @id @default(cuid())
  type        String
  description String
  createdAt   DateTime @default(now())
}

model CameraDevice {
  id        String   @id @default(cuid())
  name      String
  model     String?
  vehicle   String?
  ownerId   String?
  location  String?
  status    String   @default("offline")
  createdAt DateTime @default(now())
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  createdAt DateTime @default(now())
}
