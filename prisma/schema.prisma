generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model File {
  id        String   @id @default(cuid())
  name      String?
  url       String?
  createdAt DateTime @default(now())

  shares    Share[]
}

model Share {
  id        String   @id @default(cuid())
  fileId    String
  token     String   @unique
  createdAt DateTime @default(now())

  file      File @relation(fields: [fileId], references: [id])
}

model Incident {
  id          String   @id @default(cuid())
  type        String
  description String
  createdAt   DateTime @default(now())

  @@index([type])
}

model CameraDevice {
  id        String   @id @default(cuid())
  name      String
  location  String?
  status    String   @default("active")
  createdAt DateTime @default(now())
}