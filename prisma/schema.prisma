generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  files     File[]
}

model File {
  id        String   @id @default(cuid())
  name      String?
  createdAt DateTime @default(now())
  url       String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  shares    Share[]
}

model Share {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  fileId    String
  token     String   @unique
  file      File     @relation(fields: [fileId], references: [id])
}

model Incident {
  id          String   @id @default(cuid())
  type        String
  description String
  createdAt   DateTime @default(now())
}

model CameraDevice {
  id        String   @id @default(cuid())
  name      String
  location  String?
  status    String   @default("offline")
  createdAt DateTime @default(now())
  ownerId   String?
  vehicle   String?
  model     String?
}
