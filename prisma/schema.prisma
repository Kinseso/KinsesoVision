generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  createdAt DateTime @default(now())

  files     File[]
  folders   Folder[]
  posts     Post[]
  profile   DatingProfile?
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())

  owner     User   @relation(fields: [ownerId], references: [id])
  files     File[]
}

model File {
  id        String   @id @default(cuid())
  name      String?
  path      String?
  type      String?
  size      Int?
  ownerId   String?
  folderId  String?
  createdAt DateTime @default(now())

  owner     User?   @relation(fields: [ownerId], references: [id])
  folder    Folder? @relation(fields: [folderId], references: [id])
  shares    Share[]
}

model Share {
  id        String   @id @default(cuid())
  fileId    String
  token     String   @unique
  createdAt DateTime @default(now())

  file      File @relation(fields: [fileId], references: [id])
}

model CameraDevice {
  id        String   @id @default(cuid())
  name      String
  model     String?
  vehicle   String?
  ownerId   String?
  location  String?
  status    String   @default("offline")
  lastSeen  DateTime?
  createdAt DateTime @default(now())
}

model Incident {
  id          String   @id @default(cuid())
  type        String
  description String
  createdAt   DateTime @default(now())
}

model Post {
  id        String   @id @default(cuid())
  content   String?
  videoUrl  String?
  ownerId   String?
  createdAt DateTime @default(now())

  owner     User? @relation(fields: [ownerId], references: [id])
}

model DatingProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  bio        String?
  gender     String?
  age        Int?
  city       String?
  interests  String?
  lookingFor String?
  createdAt  DateTime @default(now())

  user       User @relation(fields: [userId], references: [id])

  likesGiven DatingLike[] @relation("likesGiven")
  likesRecv  DatingLike[] @relation("likesRecv")

  matchA     DatingMatch[] @relation("matchA")
  matchB     DatingMatch[] @relation("matchB")
}

model DatingLike {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  createdAt DateTime @default(now())

  from DatingProfile @relation("likesGiven", fields: [fromId], references: [id])
  to   DatingProfile @relation("likesRecv", fields: [toId], references: [id])
}

model DatingMessage {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  message   String
  createdAt DateTime @default(now())
}

model DatingMatch {
  id         String   @id @default(cuid())
  profileAId String
  profileBId String
  score      Float
  createdAt  DateTime @default(now())

  profileA   DatingProfile @relation("matchA", fields: [profileAId], references: [id])
  profileB   DatingProfile @relation("matchB", fields: [profileBId], references: [id])

  @@unique([profileAId, profileBId])
}